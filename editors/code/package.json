{
  "name": "banshee-vscode",
  "displayName": "banshee (PostgreSQL SQL)",
  "description": "Diagnostics, completion, formatting and more for PostgreSQL SQL via the banshee language server.",
  "version": "0.1.0",
  "private": true,
  "publisher": "octofhir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/octofhir/banshee"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Linters", "Formatters"],
  "activationEvents": ["onLanguage:sql"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "banshee",
      "properties": {
        "banshee.path": {
          "type": "string",
          "default": "banshee",
          "description": "Path to the banshee executable. Defaults to `banshee` on PATH."
        },
        "banshee.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
